generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Agent {
  id          String   @id @default(cuid())
  name        String
  role        String
  roleGroup   String   // Strategy, Tactics, Control, Execution
  status      String   @default("active") // active, idle, error, offline
  formula     String   // ToT, CoVe, ReWOO, Reflexion, ReAct, MoA
  parentId    String?
  twinId      String?   @unique
  skills      String   @default("")  // comma-separated skill names
  description String   @default("")
  avatar      String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  parent      Agent?   @relation("AgentHierarchy", fields: [parentId], references: [id])
  children    Agent[]  @relation("AgentHierarchy")
  twin        Agent?   @relation("AgentTwin", fields: [twinId], references: [id])
  twinOf      Agent?   @relation("AgentTwin")
  tasks       Task[]
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  status      String   @default("pending") // pending, running, completed, failed
  priority    String   @default("medium") // low, medium, high, critical
  agentId     String?
  agent       Agent?   @relation(fields: [agentId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Operational Architecture: Workflow Pipeline ─────────────────────────────

model Workflow {
  id            String   @id @default(cuid())
  name          String
  description   String   @default("")
  status        String   @default("draft") // draft | active | paused | archived
  triggerType   String   @default("manual") // manual | event | schedule | webhook | agent
  triggerConfig String   @default("{}") // JSON: schedule cron, event pattern, webhook URL, etc.
  version       Int      @default(1)
  tags          String   @default("") // comma-separated tags
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  steps         PipelineStep[]
  executions    WorkflowExecution[]
}

model PipelineStep {
  id             String    @id @default(cuid())
  workflowId     String
  workflow       Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  order          Int       // position in pipeline (0-based)
  name           String    // human-readable step name
  agentId        String?   // specific agent (null = any from roleGroup)
  roleGroup      String?   // agent group alternative to agentId
  action         String    @default("process") // process | review | transform | delegate | broadcast | decision
  inputSchema    String    @default("{}") // JSON: expected input data schema
  outputSchema   String    @default("{}") // JSON: output data schema
  condition      String    @default("{}") // JSON: execution condition (if/else/switch)
  fallbackStepId String?   // step ID to jump to on failure (stored as plain string for flexibility)
  timeout        Int       @default(300) // seconds
  retryPolicy    String    @default("{}") // JSON: { maxRetries, backoffMs }
  config         String    @default("{}") // JSON: step-specific config (prompt template, etc.)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  stepExecutions StepExecution[]
}

model WorkflowExecution {
  id          String        @id @default(cuid())
  workflowId  String
  workflow    Workflow      @relation(fields: [workflowId], references: [id])
  status      String        @default("running") // running | completed | failed | cancelled | paused
  taskContext String        @default("{}") // JSON: shared context — grows as pipeline progresses
  input       String        @default("{}") // JSON: initial input to the workflow
  output      String        @default("{}") // JSON: final output of the workflow
  error       String?
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  steps       StepExecution[]
}

model StepExecution {
  id            String        @id @default(cuid())
  executionId   String
  execution     WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepId        String
  step          PipelineStep  @relation(fields: [stepId], references: [id])
  agentId       String?       // agent that executed this step
  status        String        @default("pending") // pending | running | completed | failed | skipped | waiting_feedback
  inputData     String        @default("{}") // JSON: what this step received
  outputData    String        @default("{}") // JSON: what this step returned
  error         String?
  startedAt     DateTime?
  completedAt   DateTime?
  messages      AgentMessage[]
}

model AgentMessage {
  id              String        @id @default(cuid())
  stepExecutionId String
  stepExecution   StepExecution @relation(fields: [stepExecutionId], references: [id], onDelete: Cascade)
  fromAgentId     String        // sender
  toAgentId       String?       // receiver (null = broadcast within step)
  type            String        @default("request") // request | response | feedback | error | status | context_update
  content         String        @default("{}") // JSON: typed message body
  metadata        String        @default("{}") // JSON: routing info, headers, correlation IDs
  timestamp       DateTime      @default(now())
}

// ─── Z-ai Brain Center: ID-graph (added Phase C) ─────────────────────────────
// Models the 60-ID / 113-edge graph from Z-ai-platform:
//   - 19 STD-* standards (in standards/ submodule)
//   - 17 RULE-* rules (in guard/ submodule)
//   - 4 PROC-* procedures (in guard/ submodule)
//   - 6 TOOL-* tools (in guard/ submodule)
//   - 24 ZAI-* skills (in zai-skills/ submodule)
// Edges: 106 Related + 7 Aligned_with
// Source of truth: standards/standards/META-001-id-registry.md + guard/registry.json

model IdNode {
  id             String   @id // e.g. "STD-META-001", "RULE-MONOLITH-012", "TOOL-VERIFY-001"
  title          String
  category       String   // STD | RULE | PROC | TOOL | ZAI
  repo           String   // standards | guard | zai-skills
  version        String   @default("1.0")
  status         String   @default("ACTIVE") // ACTIVE | RETIRED | DEPRECATED
  level          String?  // critical | high | medium | low (RULE only)
  filePath       String?  // path to source file (relative to repo root)
  owningStandard String?  // e.g. "STD-META-001 v2.0.4"
  description    String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Edges where this node is the source
  outEdges       IdEdge[] @relation("IdEdgeSource")
  // Edges where this node is the target
  inEdges        IdEdge[] @relation("IdEdgeTarget")
}

model IdEdge {
  id           String   @id @default(cuid())
  sourceId     String
  targetId     String
  type         String   // Related | Aligned_with
  source       IdNode   @relation("IdEdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target       IdNode   @relation("IdEdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([sourceId, targetId, type])
  @@index([sourceId])
  @@index([targetId])
}

// ─── ID-graph snapshot (for fast dashboard loads) ────────────────────────────
// One row per snapshot. Captures counts + summary at a point in time.
model IdGraphSnapshot {
  id           String   @id @default(cuid())
  capturedAt   DateTime @default(now())
  platformTag  String   // e.g. "v2.6.0"
  standardsSha String
  guardSha     String
  skillsSha    String
  countsJson   String   // {"STD":19,"RULE":17,"PROC":4,"TOOL":6,"ZAI":24,"total":60}
  edgesJson    String   // {"Related":106,"Aligned_with":7,"total":113}
  topHubsJson  String   // top 5 IDs by in-degree
  isolatedJson String   // IDs with no edges
}
